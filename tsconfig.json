{
  "compilerOptions": {
    "declaration": true,
    "module": "nodenext",
    "esModuleInterop": true,
    "target": "es2022",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "lib": ["es2022"],
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**"
  ]
}
