{
  "name": "bapcsalescanada-poller",
  "version": "1.0.0",
  "description": "Poll r/bapcsalescanada and send Discord DM notifications for matching deals",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx ./src/index.ts",
    "start:prod": "node ./dist/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "lint": "eslint src --fix",
    "test": "vitest run ./src"
  },
  "author": "Mike DiDomizio",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^0.30.0"
  }
}
